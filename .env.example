# Copy this file to .env and fill in real values. .env is git-ignored.
# telek loads from os.environ first, then .env in cwd, then .env at the
# nearest git root. Process env always wins.

# Bot API token from @BotFather. Required for `telek bot/group ...`
# verbs in v0.2+.
TELEK_BOT_TOKEN=

# MTProto credentials from https://my.telegram.org/apps.
# Reserved for future use (full-roster support via telethon/pyrogram is
# deferred per the v0.2 design — telek currently uses only the Bot API).
APP_ID=
API_HASH=
