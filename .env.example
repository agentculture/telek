# Copy this file to .env and fill in real values. .env is git-ignored.
# telegram-agent loads from os.environ first, then .env in cwd, then .env at the
# nearest git root. Process env always wins.

# Bot API token from @BotFather. Required for `telegram-agent bot/group ...`
# verbs in v0.2+.
TELEGRAM_AGENT_BOT_TOKEN=

# Live smoke-test chat IDs (optional). Both must be set to enable
# tests/test_telegram_live.py. Use numeric chat IDs — Bot API doesn't
# resolve user @usernames to chat_ids.
TELEGRAM_AGENT_LIVE_TEST_USER_CHAT=
TELEGRAM_AGENT_LIVE_TEST_GROUP_CHAT=

# MTProto credentials from https://my.telegram.org/apps.
# Reserved for future use (full-roster support via telethon/pyrogram is
# deferred per the v0.2 design — telegram-agent currently uses only the Bot API).
APP_ID=
API_HASH=
